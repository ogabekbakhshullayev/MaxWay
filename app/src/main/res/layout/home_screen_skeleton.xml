<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/motion_home1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_white">

    <LinearLayout
        android:id="@+id/scrollSection1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/fixedTop1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/shimmer_color"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Доставка"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="invisible" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_down"
                        android:visibility="invisible"
                        app:tint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/shimmer_color"
                        android:fontFamily="@font/gold_play_regular"
                        android:text=" "
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/btn_search1"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:visibility="invisible"
                        app:tint="@color/black" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rvStories1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:overScrollMode="never"
            android:paddingLeft="4dp">

            <include layout="@layout/item_story_circle_skeleton" />

            <include layout="@layout/item_story_circle_skeleton" />

            <include layout="@layout/item_story_circle_skeleton" />

            <include layout="@layout/item_story_circle_skeleton" />

            <include layout="@layout/item_story_circle_skeleton" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vpAds1"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            android:background="@color/shimmer_color" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rvFilters1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#00ffffff"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:overScrollMode="never"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        app:layout_constraintTop_toBottomOf="@id/scrollSection1">

        <include layout="@layout/item_filter_chip_skeleton" />

        <include layout="@layout/item_filter_chip_skeleton" />

        <include layout="@layout/item_filter_chip_skeleton" />

        <include layout="@layout/item_filter_chip_skeleton" />
    </LinearLayout>

    <View
        android:id="@+id/rvProducts1"
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="8dp"
        android:background="@color/shimmer_color"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/rvProducts2"
        app:layout_constraintTop_toBottomOf="@id/rvFilters1" />

    <View
        android:id="@+id/rvProducts2"
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="12dp"
        android:background="@color/shimmer_color"
        app:layout_constraintLeft_toRightOf="@id/rvProducts1"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rvFilters1" />
</androidx.constraintlayout.widget.ConstraintLayout>
