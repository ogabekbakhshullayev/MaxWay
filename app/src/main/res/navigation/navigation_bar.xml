<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_bar"
    app:startDestination="@id/mainScreen">

    <fragment
        android:id="@+id/notificationFragment"
        android:name="uz.gita.maxwayappclone.presentation.screens.notification.NotificationFragment"
        android:label="NotificationFragment"
        tools:layout="@layout/screen_notification">

        <action
            android:id="@+id/action_notificationFragment_to_notificationDetailFragment"
            app:destination="@id/notificationDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/notificationDetailFragment"
        android:name="uz.gita.maxwayappclone.presentation.screens.notification_detail.NotificationDetailFragment"
        android:label="NotificationDetailFragment"
        tools:layout="@layout/screen_notification_detail" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="uz.gita.maxwayappclone.presentation.screens.search.SearchScreen"
        android:label="SearchFragment"
        tools:layout="@layout/screen_search" />
    <fragment
        android:id="@+id/branchesFragment"
        android:name="uz.gita.maxwayappclone.presentation.screens.branches.BranchesFragment"
        android:label="BranchesFragment"
        tools:layout="@layout/screen_branches">
        <action
            android:id="@+id/action_branchesFragment_to_branchDetailFragment"
            app:destination="@id/branchDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerVerifyScreen2"
        android:name="uz.gita.maxwayappclone.presentation.screens.registerVerify.RegisterVerifyScreen"
        android:label="RegisterVerifyScreen"
        tools:layout="@layout/screen_register_verify">
        <action
            android:id="@+id/action_registerVerifyScreen2_to_registerNameScreen2"
            app:destination="@id/registerNameScreen2"
            app:popUpTo="@id/registerPhoneScreen2"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/registerPhoneScreen2"
        android:name="uz.gita.maxwayappclone.presentation.screens.registerPhone.RegisterPhoneScreen"
        android:label="RegisterPhoneScreen"
        tools:layout="@layout/screen_register_phone">
        <action
            android:id="@+id/action_registerPhoneScreen2_to_registerVerifyScreen2"
            app:destination="@id/registerVerifyScreen2" />
    </fragment>
    <fragment
        android:id="@+id/registerNameScreen2"
        android:name="uz.gita.maxwayappclone.presentation.screens.registerName.RegisterNameScreen"
        android:label="RegisterNameScreen"
        tools:layout="@layout/screen_register_name" />

    <fragment
        android:id="@+id/branchDetailFragment"
        android:name="uz.gita.maxwayappclone.presentation.screens.branches.BranchDetailFragment"
        android:label="BranchDetailFragment"
        tools:layout="@layout/screen_branch_detail" />
    <dialog
        android:id="@+id/editProfileBottomSheet"
        android:name="uz.gita.maxwayappclone.presentation.screens.prfileDialog.EditProfileBottomSheet"
        android:label="EditProfileBottomSheet"
        tools:layout="@layout/dialog_bottom_edit_profile_info" />

    <fragment
        android:id="@+id/mainScreen"
        android:name="uz.gita.maxwayappclone.presentation.screens.main.MainScreen"
        android:label="MainScreen"
        tools:layout="@layout/screen_main">

        <action
            android:id="@+id/action_mainScreen_to_notificationFragment"
            app:destination="@id/notificationFragment" />
        <action
            android:id="@+id/action_mainScreen_to_editProfileBottomSheet"
            app:destination="@id/editProfileBottomSheet" />
        <action
            android:id="@+id/action_mainScreen_to_branchesFragment"
            app:destination="@id/branchesFragment" />
        <action
            android:id="@+id/action_mainScreen_to_searchFragment"
            app:destination="@id/searchFragment" />
        <action
            android:id="@+id/action_mainScreen_to_registerPhoneScreen2"
            app:destination="@id/registerPhoneScreen2" />
        <action
            android:id="@+id/action_mainScreen_to_storiesScreen2"
            app:destination="@id/storiesScreen2" />
        <action
            android:id="@+id/action_mainScreen_to_productInfoScreen2"
            app:destination="@id/productInfoScreen2" />
        <action
            android:id="@+id/action_mainScreen_to_orderPage"
            app:destination="@id/orderPage" />
    </fragment>
    <fragment
        tools:layout="@layout/screen_stories"
        android:id="@+id/storiesScreen2"
        android:name="uz.gita.maxwayappclone.presentation.screens.storiesScreen.StoriesScreen"
        android:label="StoriesScreen" />
    <fragment
        tools:layout="@layout/screen_info_product"
        android:id="@+id/productInfoScreen2"
        android:name="uz.gita.maxwayappclone.presentation.screens.productInfo.ProductInfoScreen"
        android:label="ProductInfoScreen" />
    <fragment
        tools:layout="@layout/screen_no_connection"
        android:id="@+id/noConnectionScreen"
        android:name="uz.gita.maxwayappclone.presentation.screens.noConnection.NoConnectionScreen"
        android:label="NoConnectionScreen" />
    <fragment
        android:id="@+id/orderPage"
        android:name="uz.gita.maxwayappclone.presentation.screens.orders.OrderPage"
        android:label="OrderPage"
        tools:layout="@layout/page_order"/>

</navigation>